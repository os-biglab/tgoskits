    "version": "0.2.0",
    "configurations": [
        // 暂时停用，linkscript 中添加自定义 section 后，断点无法命中
        {
            "name": "KDebug lldb",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/aarch64-unknown-none-softfloat/debug/test-suit-timer",
            "initCommands": [
                "platform select remote-gdb-server"
            ],
            "targetCreateCommands": [
                "target create ${workspaceFolder}/target/aarch64-unknown-none-softfloat/debug/test-suit-timer"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:1234" // Connect to the GDB Server
            ],
            "preLaunchTask": "qemu debug",
            "preRunCommands": [
                "target modules load --file ${workspaceFolder}/target/aarch64-unknown-none-softfloat/debug/test-suit-timer .head.text 0xFFFF900000200000",
            ]
        },
        {
            "type": "cppdbg",
            "name": "KDebug cppdbg",
            "request": "launch",
            "miDebuggerServerAddress": "localhost:1234",
            "program": "${workspaceFolder}/target/kernel.elf",
            "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb-multiarch.exe",
            "cwd": "${workspaceRoot}",
            "preLaunchTask": "qemu debug"
        },
    ]
}